#!/bin/bash

# Check that SITE is set.
if [ -z "$SITE" ]; then
    echo "Error: SITE environment variable is unset."
    echo ""
    exit 1
fi

# Check that the .env file exists
if [ ! -f "$MTMS_ENV_FILE" ]; then
    echo "Error: .env file not found at path $MTMS_ENV_FILE"
    echo ""
    exit 1
fi

# Load and export the environment variables
export $(grep -E "^(MTMS_DEVICE_GENERATION|BITFILE_VERSION|RESOURCE|CHANNEL_COUNT)=" "$MTMS_ENV_FILE" | xargs)

# Ensure required environment variables are set
if [ -z "$CHANNEL_COUNT" ] || [ -z "$MTMS_DEVICE_GENERATION" ] || [ -z "$BITFILE_VERSION" ]; then
    echo "Error: Required environment variables are unset."
    exit 1
fi

# Print the environment variables
echo "mTMS device generation: $MTMS_DEVICE_GENERATION"
echo "Bitfile version: $BITFILE_VERSION"
echo "Channel count: $CHANNEL_COUNT"

# Configure mTMS bridge
export BITFILE_DIRECTORY=$MTMS_ROOT/bitfiles
export BITFILE_PREFIX="NiFpga_mTMS_generation_${MTMS_DEVICE_GENERATION}_${BITFILE_VERSION}"
export BITFILE=$BITFILE_PREFIX.lvbitx
export BITFILE_SIGNATURE="$(cat $BITFILE_DIRECTORY/$BITFILE_PREFIX.signature)"

source $MTMS_ROOT/scripts/build-mtms-ros-workspace

# Start mTMS bridge
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp ros2 launch mtms_device_bridge mtms_device_bridge.launch.py log-level:=info safe-mode:=false channel-count:=$CHANNEL_COUNT
