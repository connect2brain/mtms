#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "$REPO_ROOT"

bash "${SCRIPT_DIR}/set-site-config" "${1:-}"

# Ensure that MATLAB is installed
if ! which matlab > /dev/null; then
    echo "MATLAB is not installed or not in the PATH."
    echo "Please install MATLAB and ensure that the executable is in the PATH."
    exit 1
fi

# Check if Ansible is installed
if ! command -v ansible-playbook &> /dev/null; then
    echo "Ansible is not installed. Installing Ansible..."
    sudo apt update
    sudo apt install -y software-properties-common
    sudo add-apt-repository --yes --update ppa:ansible/ansible
    sudo apt install -y ansible
fi

ansible-galaxy collection install -r ansible/requirements.yml > /dev/null

read -r -p "Configure static network settings? (only for production systems) (y/N): " network_response
if [[ "$network_response" =~ ^[Yy]$ ]]; then
    configure_network=true
else
    configure_network=false
fi

read -r -s -p "Enter sudo password: " SUDO_PASS
echo ""

ANSIBLE_BECOME_PASS="$SUDO_PASS" ansible-playbook -i 'localhost,' ansible/install-mtms.yml -e "configure_network=${configure_network}"

source $HOME/.bash_mtms

# Build the ROS workspace
source $MTMS_ROOT/scripts/build-mtms-ros-workspace

# Source again after building the ROS workspace
source $HOME/.bash_mtms

# Build documentation
source scripts/build-docs

# Register the pre-built MATLAB ROS interfaces.
source scripts/register-mtms-matlab

# Build mTMS containers
source scripts/build-mtms

# Build Electron app
bash scripts/build-electron-app

# Install desktop launcher
echo "Installing desktop launcher..."
bash scripts/install-mtms-desktop

echo "Done."
echo ""
echo "A reboot is required to complete the installation."
read -r -p "Reboot now? (Y/n): " reboot_response

if [[ "$reboot_response" =~ ^[Nn]([Oo])?$ ]]; then
    echo "Please reboot your computer manually to complete the installation."
else
    echo "Rebooting now..."
    sudo reboot
fi
echo ""
