# X11
#
DISPLAY=:0

# Pedal
#
PEDAL_PORT=/dev/ttyACM0
PEDAL_BAUD_RATE=9600

# Trigger device
#
TRIGGER_PORT=/dev/ttyUSB0

# Note: Baud rate does not matter, we send a constant-duration trigger pulse anyway.
TRIGGER_BAUD_RATE=9600

# EEG-TMS pipeline
#
EEG_PORT=50000

# Note: The EEG device supports two amplifiers: both have the option to connect 0-32 EEG (monopolar)
# channels and 0-8 EMG (bipolar) channels. Primary amplifier corresponds to overall channels 1-40,
# and secondary amplifier to channels 41-80. On primary amplifier, the channels 1-32 are reserved
# for EEG and channels 33-40 for EMG. Likewise, on secondary amplifier, the channels 41-72 are reserved
# for EEG and channels 73-80 for EMG.
#
# Below are example channel counts for a protocol with 64 EEG channels and a single EMG channel,
# the EMG channel connected to the secondary amplifier. Modify as needed.
#
# TODO: Unfortunately, this is a messy way to provide information about the channels. The correct
# solution would be for the EEG device manufacturer to provide the channel information in the
# measurement start packet.
#
EEG_CHANNELS_PRIMARY_AMPLIFIER=32
EMG_CHANNELS_PRIMARY_AMPLIFIER=0
EEG_CHANNELS_SECONDARY_AMPLIFIER=32
EMG_CHANNELS_SECONDARY_AMPLIFIER=1

EEG_SIMULATOR_DATA_FILE_NAME=/app/ros2_ws/src/eeg/eeg_simulator/oscillation_data.csv
EEG_SIMULATOR_SAMPLING_FREQUENCY=5000

EEG_BATCHER_BATCH_SIZE=500
EEG_BATCHER_DOWNSAMPLE_RATIO=10

# Either 'python' or 'compiledmatlab'.
EEG_PIPELINE_STAGE_TYPE=compiledmatlab
EEG_PIPELINE_STAGE_TEST_MEASURE_COUNT=10
EEG_PIPELINE_STAGE_DURATION_FILE=measurements/output.data

# FPGA
#
BITFILE=NiFpga_mTMS_Tubingen_0.4.2.lvbitx
BITFILE_SIGNATURE=325DE9B3E0A386F7E898A899A8287C0E

# Note: PXI1Slot3 for Aalto, PXI1Slot4 for Tübingen.
RESOURCE=PXI1Slot3

# Other
#
ENV_FILE=.env
ROS_LOG_LEVEL=info
