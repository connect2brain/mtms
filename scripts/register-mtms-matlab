#!/bin/bash

# Ensure that $MTMS_ROOT is set
if [ -z "$MTMS_ROOT" ]; then
    echo "Error: \$MTMS_ROOT is not set."
    echo "Please set \$MTMS_ROOT to the root directory of the mTMS repository."
    exit 1
fi

if [ ! -f "$MTMS_ROOT/api/matlab/matlab_msg_gen.zip" ]; then
    echo "Error: MATLAB message archive not found at '$MTMS_ROOT/api/matlab/matlab_msg_gen.zip'."
    echo "Build it first with: scripts/build-mtms-matlab"
    exit 1
fi

echo "  • ${BOLD}Registering the MATLAB interfaces...${RESET}"

# Register from a persistent directory outside the repository to avoid cluttering the repo.
MATLAB_REGISTER_DIR="$HOME/Documents/MATLAB/mtms"
mkdir -p "$MATLAB_REGISTER_DIR"
rm -rf "$MATLAB_REGISTER_DIR"/*

# Copy the generated package folders.
cp "$MTMS_ROOT/api/matlab/matlab_msg_gen.zip" "$MATLAB_REGISTER_DIR/"

# Register messages in MATLAB. Keep the script readable as multiline Bash,
# then join to one line for MATLAB -r.
MATLAB_BATCH_LINES=(
    "try"
    "ros2RegisterMessages('$MATLAB_REGISTER_DIR')"
    "catch ME"
    "disp(getReport(ME, 'extended', 'hyperlinks', 'off'))"
    "exit(1)"
    "end"
    "exit"
)
MATLAB_BATCH_CMD="$(printf '%s; ' "${MATLAB_BATCH_LINES[@]}")"
MATLAB_BATCH_CMD="${MATLAB_BATCH_CMD%; }"

if ! matlab -nodisplay -nosplash -nodesktop -r "$MATLAB_BATCH_CMD"; then
    echo "Error: MATLAB failed to register messages."
    exit 1
fi

echo "Done."
echo "Registered MATLAB ROS2 messages in: $MATLAB_REGISTER_DIR"
echo ""
