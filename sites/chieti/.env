# ---------------------
# Device Configuration
# ---------------------
# Current installations by generation:
# 1: Aalto
# 2: Tübingen, Chieti
MTMS_DEVICE_GENERATION=2

# Number of channels on the mTMS device.
# Aalto: 6 channels
# Tübingen, Chieti: 5 channels
CHANNEL_COUNT=5

# Coil array used with the device.
# Options:
#   - Aalto: 5-coil transducer used at Aalto
#   - Tübingen: 5-coil transducer used at Tübingen
#   - Chieti: 5-coil transducer used at Chieti
COIL_ARRAY=Chieti

# ---------------------
# Robot Configuration
# ---------------------
ROBOT_ENABLE=false

# ---------------------
# Electric Field Configuration
# ---------------------
ELECTRIC_FIELD_ENABLE=false

# ---------------------
# Pedal Configuration
# ---------------------
PEDAL_PORT=/dev/ttyACM0
PEDAL_BAUD_RATE=9600

# ---------------------
# MATLAB Configuration
# ---------------------
# In Aalto, use the network license server:
#   MLM_LICENSE_FILE=7313@lic-matlab.aalto.fi
# For Tübingen or other setups, specify the license file path, e.g.:
#   MLM_LICENSE_FILE=/usr/local/MATLAB/R2024b/licenses/license.lic
MLM_LICENSE_FILE=7313@lic-matlab.aalto.fi
USE_MATLAB_LICENSE_SERVER=true

# ---------------------
# FPGA Configuration
# ---------------------
BITFILE_VERSION=0.5.13

# FPGA resource configuration:
#   - Aalto: PXI1Slot3
#   - Tübingen, Chieti: PXI1Slot4
RESOURCE=PXI1Slot4

# ---------------------
# mTMS Simulator Configuration
# ---------------------
MTMS_DEVICE_SIMULATOR_NUM_OF_CHANNELS=5

# ---------------------
# Miscellaneous
# ---------------------
ROS_LOG_LEVEL=info
TZ=Europe/Rome
REACT_APP_LOCALE=it-IT
