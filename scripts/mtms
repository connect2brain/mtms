#!/bin/bash
# Launch mTMS Electron app

MTMS_DIR="$HOME/mtms"
APP_DIR="$MTMS_DIR/front"
ELECTRON_APP="$APP_DIR/dist-electron/linux-unpacked/mtms"

# Check if app is built
if [ ! -f "$ELECTRON_APP" ]; then
    echo "mTMS app not found. Building now..."
    cd "$APP_DIR" || exit 1

    # Install dependencies if needed
    if [ ! -d "node_modules" ]; then
        echo "Installing dependencies..."
        npm install
    fi

    # Build the app
    echo "Building app..."
    DISABLE_ESLINT_PLUGIN=true npm run build
    npm run electron-pack-linux
fi

# Focus existing instance if already running
if pgrep -f "dist-electron/linux-unpacked/mtms" > /dev/null; then
    if command -v wmctrl &> /dev/null; then
        wmctrl -xa "mTMS" 2>/dev/null || wmctrl -a "mTMS"
    else
        echo "Cannot focus window: install wmctrl"
    fi
    exit 0
fi

# Launch the app
echo "Launching mTMS..."
"$ELECTRON_APP" &
