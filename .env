#!/usr/bin/env python3
# -*- coding: utf-8 -*-

ENV_FILE=.env

# Kafka settings
KAFKA_LIBRARY=confluent-kafka

# EEG settings
BACKEND_EEG_BUFFER_LENGTH=1024

# Hosts
INIT_HOST=init
BACKEND_HOST=backend

# Ports
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092

INIT_PORT=4000
BACKEND_PORT=5000
MTMS_BRIDGE_PORT=6000

# Frontend settings
VUE_APP_BACKEND_HOST=localhost

# XXX: BACKEND_PORT is repeated here to pass it to Vue app.
VUE_APP_BACKEND_PORT=5000

# Miscellaneous
EDF_TEST_FILE=datasets/MNE-eegbci-data/files/eegmmidb/1.0.0/S001/S001R01.edf

# X11 settings
DISPLAY=193.167.0.69:0.0

# Pedal settings
PEDAL_PORT=/dev/ttyACM0
PEDAL_BAUD_RATE=9600
