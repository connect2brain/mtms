#!/bin/bash

# Define the text formatting codes
BOLD=$(tput bold)
UNDERLINE=$(tput smul)
RESET=$(tput sgr0)

echo "${BOLD}${UNDERLINE}Instructions for using the mTMS system${RESET}"
