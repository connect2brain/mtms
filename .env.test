#!/usr/bin/env python3
# -*- coding: utf-8 -*-

ENV_FILE=.env.test

# Kafka settings
#
# TODO: Test both Kafka libraries instead of only one.
#
KAFKA_LIBRARY=pykafka

# EEG settings
BACKEND_EEG_BUFFER_LENGTH=1024

# Hosts
INIT_HOST=init
BACKEND_HOST=backend

# Ports

# In tests, use the same ports as in development, but add one to each.
ZOOKEEPER_PORT=2182
KAFKA_PORT=9093

INIT_PORT=4001
BACKEND_PORT=5001
MTMS_BRIDGE_PORT=6001

# Miscellaneous
LOG_DIRECTORY=/tmp/logs
EDF_TEST_FILE=datasets/MNE-eegbci-data/files/eegmmidb/1.0.0/S001/S001R01.edf
