# Example site-specific .env file
# Place this file inside the corresponding site folder, e.g.:
#   sites/aalto/.env

# ---------------------
# ROS configuration
# ---------------------

# LOCALHOST = only local communication (default for development setup)
# SUBNET    = allow network communication (default for production setup; needed to connect with, e.g., neuronavigation computer)
ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST

# ROS logging level (e.g., debug, info, warn, error).
ROS_LOG_LEVEL=info

# ---------------------
# Device Configuration
# ---------------------

# Device generation identifier.
# Current installations by generation:
#   1: Aalto
#   2: Tübingen, Chieti
MTMS_DEVICE_GENERATION=1

# Number of channels on the mTMS device.
# Aalto:          6 channels
# Tübingen/Chieti: 5 channels
CHANNEL_COUNT=6

# Coil array configuration.
# Valid options (examples):
#   Aalto:    5-coil transducer used at Aalto
#   Tübingen: 5-coil transducer used at Tübingen
#   Chieti:   5-coil transducer used at Chieti
COIL_ARRAY=Aalto

# Ramp-down timings for each channel in ticks. Used to form the default waveform.
RAMP_DOWN_TIMINGS=1560,1560,1600,1600,1776

# ---------------------
# Robot Configuration
# ---------------------

# Enable/disable robot integration.
ROBOT_ENABLE=true

# -----------------------------
# Electric Field Configuration
# -----------------------------

# Enable/disable electric field calculation or integration.
ELECTRIC_FIELD_ENABLE=false

# ---------------------
# Pedal Configuration
# ---------------------

# Serial device path and baud rate for the pedal.
PEDAL_PORT=/dev/ttyACM0
PEDAL_BAUD_RATE=9600

# ---------------------
# MATLAB Configuration
# ---------------------

# Set to true to use a network license server (and false for local file).
USE_MATLAB_LICENSE_SERVER=false

# MATLAB network license server in port@host format.
# Used when USE_MATLAB_LICENSE_SERVER=true.
MATLAB_LICENSE_SERVER=7313@lic-matlab.aalto.fi

# MATLAB local license file path.
# Used when USE_MATLAB_LICENSE_SERVER=false.
MATLAB_LICENSE_FILE=/usr/local/MATLAB/R2025b/licenses/license.lic

# -------------------------
# Development Configuration
# -------------------------

# Set to 'true' to use the mTMS simulator instead of the real mTMS device.
USE_MTMS_SIMULATOR=false

# ---------------------
# FPGA Configuration
# ---------------------

# Bitfile version for the FPGA configuration.
BITFILE_VERSION=0.5.12

# FPGA resource identifier.
# Typical configurations:
#   Aalto:            PXI1Slot3
#   Tübingen/Chieti:  PXI1Slot4
RESOURCE=PXI1Slot3

# -----------------------------
# mTMS Simulator Configuration
# -----------------------------

# Number of channels used by the mTMS device simulator.
MTMS_DEVICE_SIMULATOR_NUM_OF_CHANNELS=6

# ---------------------
# Miscellaneous
# ---------------------

# System time zone.
TZ=Europe/Helsinki

# Default locale for the React front-end.
REACT_APP_LOCALE=fi-fi
