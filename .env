#!/usr/bin/env python3
# -*- coding: utf-8 -*-

ENV_FILE=.env

# Kafka settings
KAFKA_LIBRARY=confluent-kafka

# EEG settings
BACKEND_EEG_BUFFER_LENGTH=1024

# Hosts
INIT_HOST=init
BACKEND_HOST=backend

# Ports
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092

INIT_PORT=4000
BACKEND_PORT=5000
MTMS_BRIDGE_PORT=6000

# Frontend settings
VUE_APP_BACKEND_HOST=localhost

# XXX: BACKEND_PORT is repeated here to pass it to Vue app.
VUE_APP_BACKEND_PORT=5000

# Miscellaneous
EDF_TEST_FILE=datasets/MNE-eegbci-data/files/eegmmidb/1.0.0/S001/S001R01.edf

# X11 settings
DISPLAY=172.31.32.1:0.0

# Pedal settings
PEDAL_PORT=/dev/ttyACM0
PEDAL_BAUD_RATE=9600

# Trigger device settings
TRIGGER_PORT=/dev/ttyUSB0

# XXX: Does not matter, we are sending a constant-duration pulse anyway.
TRIGGER_BAUD_RATE=9600

EEG_SIMULATOR_DATA_FILE_NAME=/app/ros2_ws/src/eeg_simulator/oscillation_data.csv
EEG_SIMULATOR_SAMPLING_FREQUENCY=500.0

DATA_BATCHER_BATCH_SIZE=10000
DATA_BATCHER_DOWNSAMPLE_RATIO=10

# python or compiledmatlab
EEG_PROCESSOR_TYPE=compiledmatlab
EEG_PROCESSOR_TEST_MEASURE_COUNT=10
EEG_PROCESSOR_DURATION_FILE=output.data

FPGA_BRIDGE_BITFILE=NiFpga_mtms_0_3_0.lvbitx

ROS_LOG_LEVEL=info

OPTITRACK_BRIDGE_SERVER_INDEX=1
