#### Project configuration

### EEG-TMS pipeline

## Bag recording

# A bag is a database in which all communication within the system is stored during an session. The default is
# 'session1'. The bags are stored in [project-name]/bags directory under the projects directory.
#
# The default bag name can be used indefinitely; the bags are prefixed with a timestamp, so the previous bags are
# not overwritten even if the bag name does not change.
#
# When doing an session, the bag name can be used to specify the test subject, e.g., sessionname-subjectcode.
# In that case, the bag name should be changed with each new test subject.

BAG_NAME=session1

## Bag analysis (optional)

# Used only for analyzing bags. E.g., set to 'session1' to analyze bag with that name.
BAG_ANALYSIS_BAG_NAME=

# Optional; together with BAG_ANALYSIS_BAG_NAME, specifies the bag to be analyzed. For example, if
# BAG_NAME is session1 and BAG_ANALYSIS_TIMESTAMP is 2023-04-26_11-26-52, analyzes the bag stored in directory:
#
# projects/[project-name]/bags/2023-04-26_11-26-52-session1.
#
# If not given, use the latest bag matching the bag name.
#
BAG_ANALYSIS_TIMESTAMP=

# The topic to export when analyzing bags. An example value: /eeg/cleaned.
#
# To export the specified topic, run `start-service bag_exporter`.
#
BAG_ANALYSIS_TOPIC=

### Real-time pipeline

# The real-time EEG pipeline consists of three independent processing stages:
#
# - EEG preprocessor
# - EEG processor
# - Stimulus presenter
#
# They can be configured and enabled or disabled independently; for example, you can disable all of them
# to disable the real-time pipeline completely. You can also enable only EEG processor or stimulus presenter, etc.
#

## EEG preprocessor

# If enabled, preprocess raw EEG data using the specified EEG preprocessor script.
#
# Disabled as a default. To enable, set to 'true'.
#
EEG_PREPROCESSOR_ENABLE=false

# Preprocess using either 'python', 'compiledmatlab', or 'cpp' script, set the value accordingly.
EEG_PREPROCESSOR_TYPE=python

# Preprocess using the script specified below.
#
# To use a custom preprocessor script, copy the script to pipeline/[EEG_PREPROCESSOR_TYPE]/eeg_preprocessor directory under
# repository root. Then, set EEG_PREPROCESSOR_SCRIPT to point to the script; for example, to use the Python script example.py,
# set the value to pipeline.python.eeg_preprocessor.example.
#
EEG_PREPROCESSOR_SCRIPT=pipeline.python.eeg_preprocessor.dummy

## EEG processor

# If enabled, process either raw or preprocessed EEG data using the specified EEG processor script.
#
# Disabled as a default. To enable, set to 'true'.
#
EEG_PROCESSOR_ENABLE=false

# Process using either 'python', 'compiledmatlab', or 'cpp' script, set the value accordingly.
EEG_PROCESSOR_TYPE=python

# Process using the script specified below.
#
# To use a custom processor script, copy the script to pipeline/[EEG_PREPROCESSOR_TYPE]/eeg_processor directory under
# repository root. Then, set EEG_PROCESSOR_SCRIPT to point to the script; for example, to use the Python script example.py,
# set the value to pipeline.python.eeg_processor.example.
#
EEG_PROCESSOR_SCRIPT=pipeline.python.eeg_processor.dummy

## Stimulus presenter

# If enabled, present stimuli based on processed EEG data.
#
# Disabled as a default. To enable, set to 'true'.
#
STIMULUS_PRESENTER_ENABLE=false

# Present stimuli using either 'python', 'compiledmatlab', or 'cpp' script, set the value accordingly.
STIMULUS_PRESENTER_TYPE=python

# Present stimuli using the script specified below.
#
# To use a custom script, copy the script to pipeline/[EEG_PREPROCESSOR_TYPE]/stimulus_presenter directory under
# repository root. Then, set STIMULUS_PRESENTER_SCRIPT to point to the script; for example, to use the Python script example.py,
# set the value to pipeline.python.stimulus_presenter.example.
#
STIMULUS_PRESENTER_SCRIPT=pipeline.python.stimulus_presenter.dummy

## EEG simulator (optional)

# NOTE: Use only if EEG device is not available.
#
# If enabled, streams EEG data from a given csv file instead of using the actual EEG device.
#
# Disabled as a default. To enable, set to 'true'.
#
EEG_SIMULATOR_ENABLE=false

# To use custom csv data for the EEG simulator, copy the csv file to data/eeg directory in repository root.
# The columns of the file should correspond to channels and rows should correspond to datapoints. The EMG channels
# are the last channels of the file.
#
# Then, set the data filename below.
#
EEG_SIMULATOR_DATA_FILE_NAME=random_data.csv
EEG_SIMULATOR_SAMPLING_FREQUENCY=5000
EEG_SIMULATOR_NUMBER_OF_EEG_CHANNELS=64
EEG_SIMULATOR_NUMBER_OF_EMG_CHANNELS=10
