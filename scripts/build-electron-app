#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

echo "Building mTMS desktop app..."
cd "$PROJECT_ROOT/front"
npm ci
DISABLE_ESLINT_PLUGIN=true npm run build
npm run electron-pack-linux
cd "$PROJECT_ROOT"

echo "Fixing Chrome sandbox permissions..."
CHROME_SANDBOX_PATH="$PROJECT_ROOT/front/dist-electron/linux-unpacked/chrome-sandbox"
if [ -f "$CHROME_SANDBOX_PATH" ]; then
    sudo chown root:root "$CHROME_SANDBOX_PATH"
    sudo chmod 4755 "$CHROME_SANDBOX_PATH"
    echo "Chrome sandbox permissions fixed."
else
    echo "Warning: Chrome sandbox file not found at $CHROME_SANDBOX_PATH"
fi

echo "Electron app build complete!"
